@using Microsoft.AspNetCore.Components.Forms
@using UI.EmployerPortal.Razor.SharedComponents.Model
@using UI.EmployerPortal.Razor.SharedComponents.Inputs

<div class="bi-fields-grid">

    @if (ShowName)
    {
        <div class="bi-field">
            <OutlinedTextField Label="Name"
                               @bind-Value="Address.Name"
                               For="() => Address.Name"
                               Visible="Visible"
                               Disabled="Disabled" />
        </div>
        <div class="bi-field"></div>
    }

    <div class="bi-field">
        <OutlinedSelectField Label="Country"
                             Value="Address.Country"
                             ValueChanged="OnCountryChanged"
                             Options="AddressModel.Countries"
                             For="() => Address.Country"
                             Visible="Visible"
                             Disabled="Disabled" />
    </div>

    <div class="bi-field"></div>

    <div class="bi-field">
        <OutlinedTextField Label="Street Address"
                           @bind-Value="Address.AddressLine1"
                           For="() => Address.AddressLine1"
                           Placeholder="123 Main Street"
                           Visible="Visible"
                           Disabled="Disabled" />
    </div>

    <div class="bi-field">
        <OutlinedTextField Label="Suite,Apt.,Attn.,etc (Optional)"
                           @bind-Value="Address.AddressLine2"
                           Placeholder="Apt., Suite, Attn., etc."
                           Disabled="Disabled" />
    </div>

    <div class="bi-field">
        <OutlinedTextField Label="City"
                           @bind-Value="Address.City"
                           For="() => Address.City"
                           Visible="Visible"
                           Disabled="Disabled" />
    </div>

    <div class="bi-field">
        <OutlinedSelectField Label="State"
                             @bind-Value="Address.State"
                             Options="AddressModel.States"
                             Placeholder="-- Select --"
                             For="() => Address.State"
                             Visible="Visible"
                             Disabled="Disabled" />
    </div>

    <div class="bi-zip-row">
        <div class="bi-zip-field">
            <OutlinedTextField Label="Zip Code"
                               @bind-Value="Address.Zip"
                               For="() => Address.Zip"
                               Visible="Visible"
                               InputMode="numeric"
                               MaxLength="5"
                               Disabled="Disabled" />
        </div>
        <span class="bi-zip-dash">—</span>
        <div class="bi-ext-field">
            <OutlinedTextField Label="+4 (Optional)"
                               @bind-Value="Address.Extension"
                               InputMode="numeric"
                               MaxLength="4"
                               Disabled="Disabled" />
        </div>
    </div>

    @if (ShowPhone)
    {
        <div class="bi-field"></div>
        <div class="bi-phone-row">
            <PhoneNumberField Label="Phone Number"
                              Value="@Address.PhoneNumber"
                              ValueChanged="@(v => Address.PhoneNumber = v)"
                              For="() => Address.PhoneNumber"
                              ShowCountryCode="true"
                              CountryCode="@Address.PhoneCountryCode"
                              CountryCodeChanged="@(v => Address.PhoneCountryCode = v)"
                              CountryCodeDisabled="@(Address.Country != "Other International" || Disabled)"
                              Visible="Visible"
                              Disabled="Disabled" />
        </div>
    }

</div>

@code {
    /// <summary>The address model to bind all fields to.</summary>
    [Parameter, EditorRequired] public AddressModel Address { get; set; } = default!;

    /// <summary>When true, forces all field error messages to be visible (e.g. after form submit).</summary>
    [Parameter] public bool Visible { get; set; }

    /// <summary>When true, all input fields are rendered in disabled state.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>When true, an optional Name field is rendered above the address fields.</summary>
    [Parameter] public bool ShowName { get; set; }

    /// <summary>
    /// When true, a Phone Number field (with country code prefix) is rendered below the zip code row.
    /// The country code prefix is automatically pre-filled when the Country selection changes.
    /// </summary>
    [Parameter] public bool ShowPhone { get; set; }

    /// <summary>
    /// Handles country selection changes. Updates <see cref="AddressModel.Country"/> and,
    /// when <see cref="ShowPhone"/> is enabled, pre-fills <see cref="AddressModel.PhoneCountryCode"/>
    /// with the corresponding international dialing prefix.
    /// </summary>
    private void OnCountryChanged(string country)
    {
        Address.Country = country;

        if (ShowPhone)
        {
            Address.PhoneCountryCode = country switch
            {
                "United States" or "Canada" => "+1",
                _ => null  // Other International — user fills in manually
            };
        }
    }
}
