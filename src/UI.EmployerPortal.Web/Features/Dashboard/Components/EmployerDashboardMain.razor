@using Microsoft.AspNetCore.Components.Authorization
@using UI.EmployerPortal.Web.Auth
<div class="dashboard-main">
    <div class="view-toggle" role="group" aria-label="View options">
        @if (!_isListView)
        {
            <button class="toggle-btn fw-bold fs-md @(_isListView ? "active" : "")"
            @onclick="() => SetView(true)">
               Switch To List View
            </button>
        }
        else
        {
            <button class="toggle-btn fw-bold fs-md @(!_isListView ? "active" : "")"
            @onclick="() => SetView(false)">
                Switch To Grid View
            </button>
        }
    </div>

    <div class="@(_isListView ? "list-view" : "grid-view")">
        <!-- eForms -->
        <a class="dashboard-card hide-card" href="" @onclick="@(() => NavigateHere("eforms"))" @onclick:preventDefault="true">
            <div class="card-header">
                <span class="card-icon">
                    <img src="@Assets["images/dashboard/eforms.svg"]" alt="eForms" width="24" height="24" />
                </span>
                <h3 class="card-title fw-bold fs-title">eForms</h3>
            </div>
            <p class="card-description">View and respond to digital eForms sent by the WI Unemployment Insurance Division.</p>
        </a>

        <!-- Secure Messages -->
        <a class="dashboard-card hide-card" href="" @onclick="@(() => NavigateHere("secure-messages"))" @onclick:preventDefault="true">
            <div class="card-header">
                <span class="card-icon">
                    <img src="@Assets["images/dashboard/secure-messages.svg"]" alt="Secure Messages" width="24" height="24" />
                </span>
                <h3 class="card-title fw-bold fs-title">Secure Messages</h3>
            </div>
            <p class="card-description">View and respond to secure messages sent by the WI Unemployment Insurance Division.</p>
        </a>

        <!-- Quarterly Tax & Wage Reporting -->
        <AuthorizeView Policy="@AuthorizationPolicies.RequiresAnyQuarterlyTaxAndWageReportsPermission">
            <Authorized>
                <a class="dashboard-card" href="" @onclick="@(() => NavigateHere("quarterly-tax/missing-reports"))" @onclick:preventDefault="true">
                    <div class="card-header">
                        <span class="card-icon">
                            <img src="@Assets["images/dashboard/quarterly-tax.svg"]" alt="Quarterly Tax" width="24" height="24" />
                        </span>
                        <h3 class="card-title fw-bold fs-title">Quarterly Tax & Wage Reporting</h3>
                    </div>
                    <p class="card-description">File and view quarterly tax and wage reports.</p>
                    <ul class="card-list">
                        <li>File quarterly tax and wage reports</li>
                        <li>View and print previously filed reports</li>
                        <li>File quarterly tax and wage report adjustments</li>
                        <li>Elect first quarter deferral of taxes</li>
                    </ul>
                </a>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Policy="@AuthorizationPolicies.RequiresPaymentsPermission">
            <Authorized>
        <!-- Billing & Payments -->
        <a class="dashboard-card" href="" @onclick="@(() => NavigateHere("billing-payments/billing"))" @onclick:preventDefault="true">
            <div class="card-header">
                <span class="card-icon">
                    <img src="@Assets["images/dashboard/billing-payments.svg"]" alt="Billing & Payments" width="24" height="24" />
                </span>
                <h3 class="card-title fw-bold fs-title">Billing & Payments</h3>
            </div>
            <div class="card-body">
                <p class="card-description">View and manage billing and payment details.</p>
                <div class="card-info">
                    <span class="info-label fw-bold">Balance Due:</span>
                    <span class="info-value">@(EmployerAccount?.BalanceDue.ToString("C") ?? "-")</span>
                </div>
            </div>
        </a>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Policy="@AuthorizationPolicies.RequiresAnyUIAccountInformationPermission">
            <Authorized>
        <!-- UI Documents -->
        <a class="dashboard-card" href="" @onclick="@(() => NavigateHere("ui-documents"))" @onclick:preventDefault="true">
            <div class="card-header">
                <span class="card-icon">
                    <img src="@Assets["images/dashboard/ui-documents.svg"]" alt="UI Documents" width="24" height="24" />
                </span>
                <h3 class="card-title fw-bold fs-title">UI Documents</h3>
            </div>
            <p class="card-description">View documents and notices sent by the WI Unemployment Insurance Division.</p>
        </a>
            </Authorized>
        </AuthorizeView>
        

        <!-- Levies -->
        <a class="dashboard-card hide-card" href="" @onclick="@(() => NavigateHere("levies"))" @onclick:preventDefault="true">
            <div class="card-header">
                <span class="card-icon">
                    <img src="@Assets["images/dashboard/levies.svg"]" alt="Levies" width="24" height="24" />
                </span>
                <h3 class="card-title fw-bold fs-title">Levies</h3>
            </div>
            <div class="card-body">
                <p class="card-description">Respond to and make payments on active levies.</p>
                <div class="card-info">
                    <span class="info-label fw-bold">Active Levies:</span>
                    <span class="info-value">0</span>
                </div>
            </div>
        </a>


        <!-- Appeals -->
        <a class="dashboard-card hide-card" href="" @onclick="@(() => NavigateHere("appeals"))" @onclick:preventDefault="true">
            <div class="card-header">
                <span class="card-icon">
                    <img src="@Assets["images/dashboard/appeals.svg"]" alt="Appeals" width="24" height="24" />
                </span>
                <h3 class="card-title fw-bold fs-title">Appeals</h3>
            </div>
            <div class="card-body">
                <div class="card-body-left">
                    <p class="card-description">File an appeal for Tax and Benefits determinations.</p>
                    <ul class="card-list">
                        <li>File an appeal</li>
                        <li>Upload hearing documentation</li>
                        <li>Update hearing contact information</li>
                    </ul>
                </div>
                <div class="card-info-group">
                    <div class="card-info">
                        <span class="info-label fw-bold">Pending Appeals:</span>
                        <span class="info-value">0</span>
                    </div>
                    <div class="card-info">
                        <span class="info-label fw-bold">Scheduled Appeals:</span>
                        <span class="info-value">0</span>
                    </div>
                </div>
            </div>
        </a>

        <AuthorizeView Policy="@AuthorizationPolicies.RequiresManagerRole">
            <Authorized>
        <!-- View & Manage Account -->
        <a class="dashboard-card" href="" @onclick="@(() => NavigateHere("manage-account/account-users"))" @onclick:preventDefault="true">
            <div class="card-header">
                <span class="card-icon">
                    <img src="@Assets["images/dashboard/manage-account.svg"]" alt="View & Manage Account" width="24" height="24" />
                </span>
                <h3 class="card-title fw-bold fs-title">View & Manage Account</h3>
            </div>
            <p class="card-description">View and manage account details.</p>
            <ul class="card-list">
                <li>View and edit employer account information</li>
                <li>Request account access</li>
                <li>Manage worker access</li>
                <li>Employer registration</li>
                <li>Manage Employer Service Providers</li>
            </ul>
        </a>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@AuthorizationPolicies.RequiresAnyBenefitsPermissionsPermission">
            <Authorized>
        <!-- Other Functions -->
        <a class="dashboard-card" href="" @onclick="@(() => NavigateHere("other-functions/select-other-functions"))" @onclick:preventDefault="true">
            <div class="card-header">
                <span class="card-icon">
                    <img src="@Assets["images/dashboard/other-functions.svg"]" alt="Other Functions" width="24" height="24" />
                </span>
                <h3 class="card-title fw-bold fs-title">Other Functions</h3>
            </div>
            <p class="card-description">Access additional Employer Portal functions.</p>                           
            <ul class="card-list">
                <li>Download benefit charges or taxable reserve fund transactions</li>
                <li>Request 940C recertification</li>
                <li>Manage email subscriptions</li>
                <li>Upload audit files</li>                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            
            </ul>
        </a>
            </Authorized>
        </AuthorizeView>
    </div>
</div>
