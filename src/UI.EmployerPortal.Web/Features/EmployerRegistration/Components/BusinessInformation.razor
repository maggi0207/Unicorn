@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@using System.Linq.Expressions
@using UI.EmployerPortal.Razor.SharedComponents.Model
@using UI.EmployerPortal.Razor.SharedComponents.Address
@using UI.EmployerPortal.Razor.SharedComponents.NotificationBanners
@using UI.EmployerPortal.Web.Features.EmployerRegistration.Services
@using UI.EmployerPortal.Razor.SharedComponents.Validation
@using UI.EmployerPortal.Web.Features.Shared.Registrations.Models
@using UI.EmployerPortal.Razor.SharedComponents.Inputs
@using UI.EmployerPortal.Web.Features.EmployerRegistration.Models
@inject NavigationManager Nav
@inject AddressValidationCoordinator AddressCoordinator
@inject RegistrationStateService RegistrationState

<PageTitle>Business Information</PageTitle>

<div class="page_wrapper">
    <div class="bi-page-content">
        <h1 class="page-title" aria-label="buisness-information">Business Information</h1>
        <p class="page-subtitle" aria-label="noted-required-fields">All fields are required unless noted</p>

        <EditForm EditContext="@editContext" FormName="BusinessInformation" role="form">

            <DataAnnotationsValidator />
            <CustomValidator @ref="customValidator" />

            @* ================= Validation Error Summary ================= *@
            @if (_showValidationSummary && ValidationErrors.Any())
            {
                <NotificationBanner NotificationType="NotificationType.Alert"
                                    MessageStyle="MessageStyle.MultiLine"
                                    Messages="ValidationErrors"
                                    MessageFieldIds="ValidationFieldIds"
                                    DismissButton="false">
                </NotificationBanner>
                <br />
                <br />
            }

            @* ================= BUSINESS DETAILS ================= *@
            <div class="bi-fields-grid" aria-label="Fill Buisness Details">
                <div class="bi-field">
                    <OutlinedTextField Label="Legal Name"
                                       @bind-Value="Model.LegalName"
                                       For="() => Model.LegalName"
                                       Id="LegalName"
                                       Maxlength="64"
                                       OnBlur="() => ValidateCustomFields(nameof(Model.LegalName))"
                                       Visible="@IsVisible(() => Model.LegalName)" />
                </div>
                <div class="bi-field">
                    <OutlinedTextField Label="Trade Name (Optional)"
                                       @bind-Value="Model.TradeName"
                                       For="() => Model.TradeName"
                                       Id="TradeName"
                                       MaxLength="64"
                                       OnBlur="() => ValidateCustomFields(nameof(Model.TradeName))" />
                </div>
                <div class="bi-field">
                    <OutlinedTextField Label="Email Address"
                                       Type="email"
                                       @bind-Value="Model.Email"
                                       For="() => Model.Email"
                                       Placeholder="name@example.com"
                                       Id="Email"
                                       MaxLength="255"
                                       Visible="@IsVisible(() => Model.Email)" />
                </div>
            </div>

            @* ================= MAILING ADDRESS ================= *@
            <fieldset>
                <div class="bi-section-header">
                    <legend>
                        <h2 aria-labelledby="buisness-mailing-address">
                            <span id="buisness-mailing-address">Business Mailing Address</span>
                        </h2>
                    </legend>
                </div>

                <AddressField Address="Model.MailingAddress"
                              ShowPhone="true"
                              Visible="@IsAddressVisible(Model.MailingAddress)" />
            </fieldset>
            @* ================= PHYSICAL LOCATIONS ================= *@
            @for (int i = 0; i < Model.PhysicalLocations.Count; i++)
            {
                var index = i;
                <fieldset>
                    <div class="bi-section-header">
                        <legend>
                            <h2 aria-labelledby="btn-remove-physical-location">
                                <span>Physical Location @(index + 1)</span>
                                @if (index > 0)
                                {
                                    <button id="btn-remove-physical-location" type="button" class="bi-remove-location" @onclick="() => RemovePhysicalLocation(index)" aria-describedby="Physical Location @(index + 1)" aria-label="Remove Physical Location">
                                        Remove
                                    </button>
                                }
                            </h2>
                        </legend>
                    </div>

                    @if (index == 0)
                    {
                        <label class="bi-same-as-mailing @(IsMailingPoBox ? "bi-same-as-mailing--disabled" : "")" aria-labelledby="checked-same-as-mailing">
                            <input type="checkbox"
                                   id="checked-same-as-mailing"
                                   aria-label="Checked Physical Location"
                                   checked="@_physicalSameAsMailing"
                                   disabled="@IsMailingPoBox"
                                   @onchange="OnPhysicalSameAsMailingChanged" />
                            Physical Location is the same as the Business address.
                        </label>
                    }

                    <AddressField Address="Model.PhysicalLocations[index]"
                                  Visible="@IsAddressVisible(Model.PhysicalLocations[index])"
                                  Disabled="@(index == 0 && _physicalSameAsMailing)" />
                </fieldset>
            }

            @* ================= ADD LOCATION BUTTON ================= *@
            @if (Model.PhysicalLocations.Count < MaxPhysicalLocations)
            {
                <button type="button" class="bi-add-location" @onclick="AddPhysicalLocation" aria-label="Add Another Location">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <path d="M8 3V13M3 8H13"
                              stroke="#0D6EFD"
                              stroke-width="2"
                              stroke-linecap="round" />
                    </svg>
                    Add Another Physical Location
                </button>
            }

        </EditForm>

    </div>
</div>

@code {
    [Parameter] public BusinessInformationModel Model { get; set; } = new();
    [Inject] private EmployerRegistrationModelStore ModelStore { get; set; } = default!;

    private EditContext editContext = default!;
    private CustomValidator? customValidator;
    private bool formSubmitted = false;
    private bool hasValidationErrors = false;
    private bool _physicalSameAsMailing = false;
    private const int MaxPhysicalLocations = 3;
    private List<string> ValidationErrors { get; set; } = new();
    private List<string> ValidationFieldIds { get; set; } = new();
    private bool _showValidationSummary = false;

    /// <summary>Returns true when either mailing address line contains "PO Box", disabling the copy-to-physical checkbox.</summary>
    private bool IsMailingPoBox
    {
        get
        {
            return Model.MailingAddress.AddressLine1?.Contains("PO Box", StringComparison.OrdinalIgnoreCase) == true
                || Model.MailingAddress.AddressLine2?.Contains("PO Box", StringComparison.OrdinalIgnoreCase) == true;
        }
    }

    /// <summary>Tracks which fields the user has interacted with so errors show on field change.</summary>
    private HashSet<FieldIdentifier> _touchedFields = new();

    /// <summary>Initializes the edit context and restores model from state if the user navigated back.</summary>
    protected override void OnInitialized()
    {
        if (RegistrationState.BusinessInfo is not null)
            Model = RegistrationState.BusinessInfo;
        _physicalSameAsMailing = RegistrationState.PhysicalSameAsMailing;

        editContext = new EditContext(Model);
        editContext.OnFieldChanged += (_, e) =>
        {
            _touchedFields.Add(e.FieldIdentifier);

            if (ReferenceEquals(e.FieldIdentifier.Model, Model.MailingAddress) &&
                Model.PhysicalLocations.Count > 0)
            {
                if (_physicalSameAsMailing && IsMailingPoBox)
                {
                    _physicalSameAsMailing = false;
                    ClearPhysicalLocation(0);
                    NotifyPhysicalLocationChanged(0);
                }
                else if (_physicalSameAsMailing)
                {
                    CopyMailingToPhysical(0);
                    NotifyPhysicalLocationChanged(0);
                }
            }

            var allAddresses = new List<AddressModel> { Model.MailingAddress };
            allAddresses.AddRange(Model.PhysicalLocations);

            if (formSubmitted && allAddresses.Any(a => ReferenceEquals(a, e.FieldIdentifier.Model)))
            {
                InvokeAsync(() =>
                {
                    customValidator?.ClearErrors();
                    var errors = ValidateAddressModels();
                    if (errors.Any()) customValidator?.DisplayErrors(errors);
                    hasValidationErrors = editContext.GetValidationMessages().Any();
                    StateHasChanged();
                });
            }
            else
            {
                hasValidationErrors = editContext.GetValidationMessages().Any();
                StateHasChanged();
            }
        };
    }

    private Dictionary<FieldIdentifier, List<string>> _customFieldErrors = new();

    /// <summary>Validation for Legal Name</summary>
    private void ValidateCustomFields(string fieldName)
    {
        //var errors = new Dictionary<FieldIdentifier, List<string>>();
        var fieldId = new FieldIdentifier(Model, fieldName);
        var ownershipType = ModelStore.EmployerRegistrationModel.OwnershipSessionData?.OwnershipType ?? OwnershipType.None;
        //customValidator?.ClearErrors();
        _customFieldErrors.Remove(fieldId);

        if (fieldName == nameof(Model.LegalName))
        {
            if (ownershipType == OwnershipType.LLC &&
                !string.IsNullOrWhiteSpace(Model.LegalName) &&
                !Model.LegalName.TrimEnd().EndsWith("LLC", StringComparison.OrdinalIgnoreCase))
            {
                _customFieldErrors[fieldId] = new List<string>
               { "Legal Name must end in LLC for a Limited Liability Company" };
            }
        }
        // Trade Name validations (only if provided)

        if ((fieldName == nameof(Model.TradeName)) && !string.IsNullOrWhiteSpace(Model.TradeName))

        {
            var messages = new List<string>();
            if (Model.TradeName.Equals(Model.LegalName, StringComparison.OrdinalIgnoreCase))
                messages.Add(("Trade Name cannot be the same as Legal Name"));

            if (Model.TradeName.TrimEnd().EndsWith("LLC", StringComparison.OrdinalIgnoreCase))
                messages.Add(("Trade Name cannot end with LLC"));

            if (Model.TradeName.TrimEnd().EndsWith("Inc", StringComparison.OrdinalIgnoreCase))
                messages.Add(("Trade Name cannot end with Inc"));

            if (messages.Any())
                _customFieldErrors[fieldId] = messages;

        }

        if (_customFieldErrors.Any())
        {
            _touchedFields.Add(fieldId);
            customValidator?.ClearErrors();
            customValidator?.DisplayErrors(_customFieldErrors);

            StateHasChanged();
        }
    }

    /// <summary>
    /// Validates the form and runs service-side address validation.
    /// Returns true when all validations pass (wizard may advance).
    /// Returns false when validation fails or when navigating to address correction.
    /// </summary>
    public async Task<bool> Validate()
    {
        formSubmitted = true;
        customValidator?.ClearErrors();
        _customFieldErrors.Clear();

        ValidationErrors.Clear();
        ValidationFieldIds.Clear();
        _showValidationSummary = false;
        var topLevelValid = editContext.Validate();

        ValidateCustomFields(nameof(Model.LegalName));
        ValidateCustomFields(nameof(Model.TradeName));


        ValidationErrors.Clear();
        ValidationFieldIds.Clear();
        foreach (var (fi, messages) in _customFieldErrors)
        {
            foreach (var message in messages)
            {
                ValidationErrors.Add(message);
                ValidationFieldIds.Add(fi.FieldName);
            }
        }
        if (_customFieldErrors.Any())
            _showValidationSummary = true;


        var addressErrors = ValidateAddressModels();

        if (addressErrors.Any())
            customValidator?.DisplayErrors(addressErrors);

        if (!topLevelValid || _customFieldErrors.Any())
        {
            var customFieldNames = _customFieldErrors.Keys.Select(k => k.FieldName).ToHashSet();
            var properties = Model.GetType().GetProperties();

            foreach (var prop in properties)
            {
                if (customFieldNames.Contains(prop.Name)) continue;
                var fieldId = new FieldIdentifier(Model, prop.Name);
                var errors = editContext.GetValidationMessages(fieldId);

                foreach (var error in errors)
                {
                    ValidationErrors.Add(error);
                    ValidationFieldIds.Add(prop.Name);
                    _showValidationSummary = true;
                }
            }

            if (addressErrors.Any())
            {
                ValidationErrors.AddRange(addressErrors.Values.SelectMany(v => v).ToList());
                ValidationFieldIds.AddRange(addressErrors.Keys.Select(k => k.FieldName.ToString() ?? string.Empty).ToList());

                _showValidationSummary = true;
            }

            hasValidationErrors = true;
            editContext.NotifyValidationStateChanged();
            StateHasChanged();
            return false;
        }

        hasValidationErrors = false;


        RegistrationState.BusinessInfo = Model;
        RegistrationState.PhysicalSameAsMailing = _physicalSameAsMailing;
        var startIndex = _physicalSameAsMailing ? 1 : 0;

        var addressesToValidate = new List<(string, AddressModel)>
            { ("Mailing Address", Model.MailingAddress) };
        for (var i = startIndex; i < Model.PhysicalLocations.Count; i++)
            addressesToValidate.Add(($"Physical Location {i + 1} Address", Model.PhysicalLocations[i]));
        var usAddressesToValidate = addressesToValidate.Where(a => a.Item2.Country == "United States").ToList();

        return await AddressCoordinator.ValidateAndRedirectAsync(
            usAddressesToValidate,
            editStep: 3,
            postCorrectionStep: 4);
    }

    /// <summary>Handles the "Physical Location is the same as the Business address" checkbox toggle.</summary>
    private void OnPhysicalSameAsMailingChanged(ChangeEventArgs e)
    {
        _physicalSameAsMailing = e.Value is true;
        if (_physicalSameAsMailing)
            CopyMailingToPhysical(0);
        else
            ClearPhysicalLocation(0);
        NotifyPhysicalLocationChanged(0);
        StateHasChanged();
    }

    /// <summary>Copies all mailing address fields into PhysicalLocations[<paramref name="index"/>].</summary>
    private void CopyMailingToPhysical(int index)
    {
        var src = Model.MailingAddress;
        var dest = Model.PhysicalLocations[index];
        dest.Country = src.Country;
        dest.AddressLine1 = src.AddressLine1;
        dest.AddressLine2 = src.AddressLine2;
        dest.City = src.City;
        dest.State = src.State;
        dest.Province = src.Province;
        dest.Zip = src.Zip;
        dest.PostalCode = src.PostalCode;
        dest.Extension = src.Extension;
    }

    /// <summary>Notifies the EditContext that all fields on PhysicalLocations[<paramref name="index"/>] have changed, triggering re-validation.</summary>
    private void NotifyPhysicalLocationChanged(int index)
    {
        var dest = Model.PhysicalLocations[index];
        editContext.NotifyFieldChanged(new FieldIdentifier(dest, nameof(AddressModel.Country)));
        editContext.NotifyFieldChanged(new FieldIdentifier(dest, nameof(AddressModel.AddressLine1)));
        editContext.NotifyFieldChanged(new FieldIdentifier(dest, nameof(AddressModel.AddressLine2)));
        editContext.NotifyFieldChanged(new FieldIdentifier(dest, nameof(AddressModel.City)));
        editContext.NotifyFieldChanged(new FieldIdentifier(dest, nameof(AddressModel.State)));
        editContext.NotifyFieldChanged(new FieldIdentifier(dest, nameof(AddressModel.Province)));
        editContext.NotifyFieldChanged(new FieldIdentifier(dest, nameof(AddressModel.Zip)));
        editContext.NotifyFieldChanged(new FieldIdentifier(dest, nameof(AddressModel.PostalCode)));
        editContext.NotifyFieldChanged(new FieldIdentifier(dest, nameof(AddressModel.Extension)));
    }

    /// <summary>Clears all fields on PhysicalLocations[<paramref name="index"/>].</summary>
    private void ClearPhysicalLocation(int index)
    {
        var dest = Model.PhysicalLocations[index];
        dest.Country = null;
        dest.AddressLine1 = null;
        dest.AddressLine2 = null;
        dest.City = null;
        dest.State = null;
        dest.Province = null;
        dest.Zip = null;
        dest.PostalCode = null;
        dest.Extension = null;
    }

    /// <summary>Returns true when a field's errors should be visible (after submission or interaction).</summary>
    private bool IsVisible(Expression<Func<string?>> For)
        => formSubmitted || _touchedFields.Contains(FieldIdentifier.Create(For));

    /// <summary>Returns true when an address section's errors should be visible.</summary>
    private bool IsAddressVisible(AddressModel address)
        => formSubmitted || _touchedFields.Any(f => ReferenceEquals(f.Model, address));

    /// <summary>Runs DataAnnotations validation on all address models.</summary>
    private Dictionary<FieldIdentifier, List<string>> ValidateAddressModels()
    {
        var errors = new Dictionary<FieldIdentifier, List<string>>();

        var physicalToValidate = _physicalSameAsMailing
            ? Model.PhysicalLocations.Skip(1)
            : Model.PhysicalLocations;

        var allAddresses = new List<AddressModel> { Model.MailingAddress };
        allAddresses.AddRange(physicalToValidate);

        foreach (var address in allAddresses)
        {
            var ctx = new ValidationContext(address);
            var results = new List<ValidationResult>();
            Validator.TryValidateObject(address, ctx, results, true);

            foreach (var result in results)
            {
                foreach (var memberName in result.MemberNames)
                {
                    var fi = new FieldIdentifier(address, memberName);
                    if (!errors.ContainsKey(fi))
                        errors[fi] = new List<string>();
                    errors[fi].Add(result.ErrorMessage ?? "This field is invalid");
                }
            }
        }

        // Validate mailing address phone (shown only on mailing address, so not on AddressModel itself)
        var phoneField = new FieldIdentifier(Model.MailingAddress, nameof(AddressModel.PhoneNumber));
        var phoneTypeField = new FieldIdentifier(Model.MailingAddress, nameof(AddressModel.PhoneType));
        var phoneCountryCodeField = new FieldIdentifier(Model.MailingAddress, nameof(AddressModel.PhoneCountryCode));

        if (Model.MailingAddress.Country != "United States" && string.IsNullOrWhiteSpace(Model.MailingAddress.PhoneType))
        {
            if (!errors.ContainsKey(phoneTypeField)) errors[phoneTypeField] = new List<string>();
            errors[phoneTypeField].Add("Phone Type is required");
        }

        if (Model.MailingAddress.PhoneType == "Other International" && string.IsNullOrWhiteSpace(Model.MailingAddress.PhoneCountryCode))
        {
            if (!errors.ContainsKey(phoneCountryCodeField)) errors[phoneCountryCodeField] = new List<string>();
            errors[phoneCountryCodeField].Add("International Area Code is required");
        }

        if (string.IsNullOrWhiteSpace(Model.MailingAddress.PhoneNumber))
        {
            if (!errors.ContainsKey(phoneField)) errors[phoneField] = new List<string>();
            errors[phoneField].Add("Phone Number is required");
        }
        else if ((Model.MailingAddress.Country == "United States" || Model.MailingAddress.Country == "Canada") 
                 && !System.Text.RegularExpressions.Regex.IsMatch(Model.MailingAddress.PhoneNumber, @"^\d{3}-\d{3}-\d{4}$"))
        {
            if (!errors.ContainsKey(phoneField)) errors[phoneField] = new List<string>();
            errors[phoneField].Add("Phone Number must be in format 999-999-9999");
        }

        foreach (var physical in physicalToValidate)
        {
            bool line1IsPoBox = physical.AddressLine1?.Contains("PO Box", StringComparison.OrdinalIgnoreCase) == true;
            bool line2IsPoBox = physical.AddressLine2?.Contains("PO Box", StringComparison.OrdinalIgnoreCase) == true;

            if (line1IsPoBox)
            {
                var fi = new FieldIdentifier(physical, nameof(AddressModel.AddressLine1));
                if (!errors.ContainsKey(fi))
                    errors[fi] = new List<string>();
                errors[fi].Add("Physical location cannot be a PO Box. Please enter a street address");
            }

            if (line2IsPoBox)
            {
                var fi = new FieldIdentifier(physical, nameof(AddressModel.AddressLine2));
                if (!errors.ContainsKey(fi))
                    errors[fi] = new List<string>();
                errors[fi].Add("Physical location cannot be a PO Box. Please enter a street address");
            }
        }

        return errors;
    }

    /// <summary>Adds a new physical location up to the maximum allowed.</summary>
    private void AddPhysicalLocation()
    {
        if (Model.PhysicalLocations.Count < MaxPhysicalLocations)
        {
            Model.PhysicalLocations.Add(new AddressModel());
            StateHasChanged();
        }
    }

    /// <summary>Removes the physical location at the specified index.</summary>
    private void RemovePhysicalLocation(int index)
    {
        if (Model.PhysicalLocations.Count > 1 && index >= 0 && index < Model.PhysicalLocations.Count)
        {
            Model.PhysicalLocations.RemoveAt(index);
            customValidator?.ClearErrors();
            StateHasChanged();
        }
    }
}
