@using System.ComponentModel.DataAnnotations
@using UI.EmployerPortal.Razor.SharedComponents.Address
@using UI.EmployerPortal.Razor.SharedComponents.Inputs;
@using UI.EmployerPortal.Web.Features.EmployerRegistration.Components;
@using UI.EmployerPortal.Web.Features.EmployerRegistration.Models;
@using UI.EmployerPortal.Web.Features.Shared.Registrations.Models;
@using System.Linq.Expressions
@inject NavigationManager Nav;

<PageTitle>Preliminary Questions</PageTitle>

<div class="page_wrapper">
    <div class="bi-page-content">
        <h1 class="page-title">Preliminary Questions</h1>
        <p class="page-subtitle">All fields are required unless noted</p>

        <EditForm EditContext="_editContext">

            <!-- FEIN -->
            <FEINField Label="FEIN"
                       @bind-Value="Model.FEIN"
                       For="() => Model.FEIN"
                       Placeholder="99-9999999" />
            <br />

            <!-- UI Account Number -->
            <!--Use Mask shared component at line 23 as reference in all your pages whereever needed-->
            <OutlinedTextField Label="Employer UI Account Number (Optional)"
                               @bind-Value="Model.UIAccountNumber"
                               For="() => Model.UIAccountNumber"
                               Mask="000000-000-0"
                               Placeholder="999999-999-9" />
            <br />

            <!-- Question 1 -->
            <p>Select your business category. <span class="fw-bold">To be considered a non-profit organization by the State of Wisconsin, you must have recieved a 501(c)(3) determination from the IRS</span></p>
            <FieldError For="@(() => Model.BusinessCategory)"
                        Visible="@_formSubmitted" />
            <RadioGroup TValue="BusinessCategory ?"
                        Value="Model.BusinessCategory"
                        ValueChanged="OnBusinessCategoryChanged"
                        ValueExpression="() => Model.BusinessCategory"
                        Options="@BusinessCategoryOptions" />
            <br />

            <!-- Question 2 -->
            <p>Have you acquired through sale, reorganization or other means an existing business operation in Wisconsin?</p>
            <FieldError For="@(() => Model.AcquiredExistingBusiness)"
                        Visible="@_formSubmitted" />
            <RadioGroup TValue="bool?"
                        Value="Model.AcquiredExistingBusiness"
                        ValueChanged="OnAcquiredExistingBusinessChanged"
                        ValueExpression="() => Model.AcquiredExistingBusiness"
                        Options="@YesNoRadioOptions" />
            <br />

            @if (VisibilityQuestion_2_1)
            {
                <!-- Question 2.1 -->
                <p data-questionid="2.1">Do you know the Account Number of the acquired business?</p>
                <FieldError For="@(() => Model.KnowAcquiredBusinessAccountNumber)"
                            Visible="@_formSubmitted" />
                <RadioGroup TValue="bool?"
                            Value="Model.KnowAcquiredBusinessAccountNumber"
                            ValueChanged="OnKnowAcquiredBusinessAccountNumberChanged"
                            ValueExpression="() => Model.KnowAcquiredBusinessAccountNumber"
                            Options="@YesNoRadioOptions"/>
                <br />

                @if (VisibilityQuestion_2_1_1)
                {
                    <!-- Question 2.1.1 (Question 2.1 Yes) -->
                    <span data-questionid="2.1.1"></span>
                    <OutlinedTextField Label="Acquired business Employer UI Account Number"
                                       @bind-Value="Model.AcquiredBusinessAccountNumber"
                                       For="() => Model.AcquiredBusinessAccountNumber"
                                       Mask="000000-000-0"
                                       Placeholder="999999-999-9" />
                    <br />
                }
                else if (VisibilityQuestion_2_1_2)
                {
                    <!-- Question  2.1.2 (Question 2.1 No) -->
                    <span data-questionid="2.1.2"></span>
                    <OutlinedTextField Label="Name of the acquired business"
                                       @bind-Value="Model.AcquiredBusinessName"
                                       For="() => Model.AcquiredBusinessName"/>
                    <br />

                    <p>Current Address of Acquired Business</p>
                    <AddressField Address="Model.AcquiredBusinessAddress"
                                  Visible="true"
                                  ErrorVisibleForField="(_) => _formSubmitted"/>
                    <br />
                }
            }

            @if (VisibilityQuestion_3)
            {
                <!-- Question 3 -->
                <p data-questionid="3">Have you paid employees for work performed in Wisconsin?<br /><span class="fw-bold">Do not include wages that have not yet been paid out, or wages reportable to a state other than Wisconsin.</span></p>
                <FieldError For="@(() => Model.HavePaidEmployeesForWorkInWisconsin)"
                            Visible="@_formSubmitted" />
                <RadioGroup TValue="bool?"
                            Value="Model.HavePaidEmployeesForWorkInWisconsin"
                            ValueChanged="OnHavePaidEmployeesForWorkInWisconsinChanged"
                            ValueExpression="() => Model.HavePaidEmployeesForWorkInWisconsin"
                            Options="@YesNoRadioOptions"/>
                <br />


                @if (VisibilityQuestion_3_1)
                {
                    <!-- Question 3.1 (Question 3 Yes) -->
                    <p data-questionid="3.1">Do you still have paid employees working in Wisconsin?</p>
                    <FieldError For="@(() => Model.HaveEmployeesCurrentlyWorkingInWisconsin)"
                                Visible="@_formSubmitted" />
                    <RadioGroup TValue="bool?"
                                Value="Model.HaveEmployeesCurrentlyWorkingInWisconsin"
                                ValueChanged="OnHaveEmployeesCurrentlyWorkingInWisconsinChanged"
                                ValueExpression="() => Model.HaveEmployeesCurrentlyWorkingInWisconsin"
                                Options="@YesNoRadioOptions"/>
                    <br />
                    @if (VisibilityCheckbox_InfoAccurate)
                    {
                        <div class="form-check">
                            <input type="checkbox"
                                   id="chk-info-accurate"
                                   class="form-check-input @(_formSubmitted && !Model.InformationIsAccurate ? "invalid" : "")"
                                   @bind="Model.InformationIsAccurate"
                                   @bind:after="OnInformationIsAccurateChanged" />
                            <label class="form-check-label fw-bold" for="chk-info-accurate">
                                The information provided is true and accurate to the best of my knowledge.
                            </label>
                        </div>
                        <FieldError For="@(() => (object)Model.InformationIsAccurate)" Visible="@_formSubmitted" />
                        <br />
                    }

                    @* @if (VisibilityQuestion_3_1_2)
                    {
                        <!-- Question 3.1.2 (Question 3.1 No) -->
                        <span data-questionid="3.1.2"></span>
                        <OutlinedTextField Label="Last Employment Date"
                                           Type="date"
                                           @bind-Value="LastEmploymentDateAsString"
                                           For="() => LastEmploymentDateAsString" />
                        <br />

                        <OutlinedTextField Label="Last Payroll Date"
                                           Type="date"
                                           @bind-Value="LastPayrollDateAsString"
                                           For="() => LastPayrollDateAsString" />
                        <br />
                    } *@
                }
                 @if(VisibilityQuestion_3_2)
                {
                    <!-- Question 3.2 (Question 3 No) -->
                    <p data-questionid="3.2">Do you expect to pay wages for work performed in Wisconsin in the future?</p>
                    <FieldError For="@(() => Model.ExpectFuturePayroll)"
                                Visible="@_formSubmitted" />
                    <RadioGroup TValue="bool?"
                                Value="Model.ExpectFuturePayroll"
                                ValueChanged="OnExpectFuturePayrollChanged"
                                ValueExpression="() => Model.ExpectFuturePayroll"
                                Options="@YesNoRadioOptions"/>
                    <br />

                    <!-- Question 3.2.1 (Question 3.2 Yes) -->
                    @if (VisibilityQuestion_3_2_1)
                    {
                        <span data-questionid="3.2.1"></span>
                        <OutlinedSelectField Label="When?"
                                             @bind-Value="ExpectedFuturePayrollPeriodAsString"
                                             Options="FuturePayPeriodOptions"
                                             For="() => ExpectedFuturePayrollPeriodAsString"/>
                        <FieldError For="@(() => Model.ExpectedFuturePayrollPeriod)"
                                    Visible="@_formSubmitted" />
                        <br />
                    }
                }
            }

            @* <!-- Question 4 (Question 3.1 Yes) -->
            @if (VisibilityQuestion_4)
            {
                <p data-questionid="4">Did you sell or transfer your business?</p>
                <FieldError For="@(() => Model.HaveSoldOrTransferredBusiness)"
                            Visible="@_formSubmitted" />
                <RadioGroup TValue="bool?"
                            Value="Model.HaveSoldOrTransferredBusiness"
                            ValueChanged="OnHaveSoldOrTransferredBusinessChanged"
                            ValueExpression="() => Model.HaveSoldOrTransferredBusiness"
                            Options="@YesNoRadioOptions" />
                <br />
            }--Removing this question as per story 824 *@

            @if (VisibilityQuestion_4)
            {
                <div class="no-employee-section">
                    <p class="section-title">
                        Select the reason you no longer have paid employees working in Wisconsin.
                    </p>
                    <FieldError For="@(() => Model.SelectedNoEmployeeReason)"
                                Visible="@_formSubmitted" />
                    <RadioGroup TValue="NoEmployeeReason?"
                                Value="Model.SelectedNoEmployeeReason"
                                ValueChanged="OnNoEmployeReasonChanged"
                                ValueExpression="() => Model.SelectedNoEmployeeReason"
                                Options="@NoEmployeReasonOptions" />
                    @if (Model.SelectedNoEmployeeReason == NoEmployeeReason.NotOperatingInWisconsin)
                    {
                        <!-- Question 3.1.2 (Question 3.1 No) -->
                        <span data-questionid="3.1.2"></span>
                        <OutlinedTextField Label="Last Employment Date"
                                           Type="date"
                                           @bind-Value="LastEmploymentDateAsString"
                                           For="() => LastEmploymentDateAsString"
                                           Visible="@IsVisible(()=>Model.LastEmploymentDate)" />
                        <br />

                        <OutlinedTextField Label="Last Payroll Date"
                                           Type="date"
                                           @bind-Value="LastPayrollDateAsString"
                                           For="() => LastPayrollDateAsString"
                                           Visible="@IsVisible(()=>Model.LastPayrollDate)" />
                        <br />
                    }
                    @if (Model.SelectedNoEmployeeReason == NoEmployeeReason.LeasingFromPEO)
                    {
                        <div class="peo-container">
                            <div class="field-wrapper peo-name">
                                <OutlinedTextField Label="PEO Name"
                                                   @bind-Value="Model.PEOName"
                                                   For="() => Model.PEOName"
                                                   Visible="@IsVisible(()=>Model.PEOName)" />
                            </div>
                            <br/>
                            <div class="peo-row">
                                <div class="peo-ui">
                                    <OutlinedTextField Label="PEO UI Account Number"
                                                       @bind-Value="Model.PEOUIAccountNumber"
                                                       For="() => Model.PEOUIAccountNumber"
                                                       Mask="000000-000-0"
                                                       Placeholder="999999-999-9"
                                                       Visible="@IsVisible(()=>Model.PEOUIAccountNumber)" />
                                </div>

                                <span class="or-text">OR</span>

                                <div class="peo-fein">
                                    <OutlinedTextField Label="PEO FEIN"
                                                       Value="@_peoValue"
                                                       ValueChanged="OnInput"
                                                       For="() => Model.PEOFEIN"
                                                       Placeholder="11-2233445"
                                                       MaxLength="10"
                                                       Visible="@IsVisible(()=>Model.PEOFEIN)" />
                                </div>
                            </div>
                            <br />
                            <div class="field-wrapper peo-date">
                                <OutlinedTextField Label="Date leasing agreement started"
                                                   Type="date"
                                                   @bind-Value="LeasingStartDateAsString"
                                                   For="() => LeasingStartDateAsString"
                                                   Visible="@IsVisible(()=>Model.LeasingStartDate)" />
                            </div>
                        </div>
                    }
                    @if (Model.SelectedNoEmployeeReason == NoEmployeeReason.BusiessWithoutEmployees)
                    {
                        <div class="no-employee-reason-wrapper">
                            <OutlinedTextField Label="Enter the reason for business continuation."
                                               @bind-Value="Model.NoEmployeeExplanation"
                                               For="() => Model.NoEmployeeExplanation" />
                        </div>
                    }

                    @if (Model.SelectedNoEmployeeReason == NoEmployeeReason.FiscalAgent)
                    {
                        <div class="fiscal-container">
                            <!-- Row: Fiscal Agent Name (half width) -->
                            <div class="fiscal-row">
                                <div class="field-wrapper fiscal-half">
                                    <OutlinedTextField Label="Fiscal Agent Name"
                                                       @bind-Value="Model.FiscalAgentName"
                                                       For="() => Model.FiscalAgentName"
                                                       Visible="@IsVisible(()=>Model.FiscalAgentName)" />
                                </div>
                            </div>
                            <br />
                            <!-- Full width: UI Account Number -->
                            <div class="field-wrapper fiscal-full">
                                <OutlinedTextField Label="Fiscal Agent UI Account Number"
                                                   @bind-Value="Model.FiscalAgentUIAccountNumber"
                                                   For="() => Model.FiscalAgentUIAccountNumber"
                                                   Mask="000000-000-0"
                                                   Placeholder="999999-999-9"
                                                   Visible="@IsVisible(()=>Model.FiscalAgentUIAccountNumber)" />
                            </div>
                        </div>
                    }
                    @if (Model.SelectedNoEmployeeReason == NoEmployeeReason.Other)
                    {
                        <div class="field-wrapper provide-reason">
                            <OutlinedTextField Label="Provide reason"
                                               @bind-Value="Model.OtherReason"
                                               For="() => Model.OtherReason"
                                               Visible="@IsVisible(()=>Model.OtherReason)" />
                        </div>
                    }
                </div>
            }
        </EditForm>
    </div>
</div>
