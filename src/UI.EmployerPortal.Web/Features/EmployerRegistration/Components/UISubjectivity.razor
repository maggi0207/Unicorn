@page "/employer-registration/UISubjectivity";

@using UI.EmployerPortal.Razor.SharedComponents.Address
@using UI.EmployerPortal.Razor.SharedComponents.Helpers
@using UI.EmployerPortal.Razor.SharedComponents.Inputs
@using UI.EmployerPortal.Razor.SharedComponents.TextBoxes
@using UI.EmployerPortal.Web.Features.EmployerRegistration.Components;
@using UI.EmployerPortal.Web.Features.EmployerRegistration.Models
@using UI.EmployerPortal.Web.Features.Shared.Registrations.Models;
@using UI.EmployerPortal.Razor.SharedComponents.Validation

@inject EmployerRegistrationInfo RegistrationInfo;
@inject NavigationManager Nav;

<PageTitle>Unemployment Insurance Subjectivity</PageTitle>

<div class="page_wrapper">
    <div class="ui-page-content">

        <h1 class="page-title">Unemployment Insurance Subjectivity</h1>
        <p class="page-subtitle">
            These answers will help us determine whether your business is covered under Wisconsin's Unemployment Insurance Law. All fields are required unless noted.
        </p>

        <EditForm Model="@_subjectivityContext" FormName="UISubjectivity">
            
            <DataAnnotationsValidator />
            <CustomValidator @ref="_customValidator" />

            <p class="page-subtitle">
                Select your business category. <strong>To be considered a non-profit organization by the State of Wisconsin, you must have received a 501(c)(3) determination from the IRS.</strong>
            </p>

            <div id="section_1" class="ui-radio-section">
                @if (_businessCategoryLockedFromStep1)
                {
                    <!-- NonProfit_501c3 was set in Step 1: show greyed-out pre-selected option, then remaining interactive options -->
                    <div class="ui-radio-locked-option">
                        <input type="radio" disabled checked id="bc-nonprofit-501c3" />
                        <label for="bc-nonprofit-501c3" class="ui-radio-locked-label">Non-Profit with 501(c)(3) Ruling from IRS</label>
                    </div>
                    <RadioGroup TValue="BusinessCategory?"
                                Value="SubjectivityModel.BusinessCategory"
                                ValueChanged="OnBusinessCatagoryChanged"
                                ValueExpression="() => SubjectivityModel.BusinessCategory"
                                Options="@BusinessCategoriesLockedAlternatives" />
                    <FieldError For="@(() => SubjectivityModel.BusinessCategory)"
                                Visible="_formSubmitted" />
                }
                else
                {
                    <RadioGroup TValue="BusinessCategory?"
                                Value="SubjectivityModel.BusinessCategory"
                                ValueChanged="OnBusinessCatagoryChanged"
                                ValueExpression="() => SubjectivityModel.BusinessCategory"
                                Options="@BusinessCatagories" />
                    <FieldError For="@(() => SubjectivityModel.BusinessCategory)"
                                Visible="_formSubmitted" />
                }

            </div>

            @if (Section2Visible())
            {
                <div id="section_2" class="ui-radio-section">
                    <p class="page-subtitle">Have you applied for 501(c)(3) status with the IRS?</p>
                    <br />
                    <RadioGroup TValue="bool?"
                                Value="SubjectivityModel.HasAppliedFor501c3Status"
                                ValueChanged="OnHasAppliedFor501c3StatusChange"
                                ValueExpression="() => SubjectivityModel.HasAppliedFor501c3Status"
                                Options="@HasAppliedFor501c3Status" />
                    <FieldError For="@(() => SubjectivityModel.HasAppliedFor501c3Status)"
                                Visible="_formSubmitted" />

                    @if (SubjectivityModel.HasAppliedFor501c3Status == true)
                    {
                        <p class="ui-text"><strong>Please return to step one to correct your answer regarding your 501(c)(3) designation.</strong></p>
                    }
                </div>
            }

            <div class="ui-section-header">
                <span>Financial Institution for Business Checking Account</span>
            </div>

            <AddressField Address="SubjectivityModel.FinancialInstitution"
                          ShowName="true"
                          Visible="@_showAddressErrors" />

            <div class="ui-radio-section">
                <p class="ui-text"><strong>Note: </strong>@GetNoteText()<a href=@GetPermittedExclusionsUrl() class="link-underline-primary">Permitted Exclusions</a></p>
            </div>


            @if (Section3Visible())
            {
                <div id="section3" class="ui-radio-section">
                    <p class="ui-text">Do you have employees who work in states other than Wisconsin?</p>
                    <RadioGroup TValue="bool?"
                    Value="SubjectivityModel.HasEmployeesOutsideWisconsin"
                    ValueChanged="OnHasEmployeesOutsideWisconsinChange"
                    ValueExpression="() => SubjectivityModel.HasEmployeesOutsideWisconsin"
                    Options="@HasEmployeesOutsideWisconsin" />
                    <FieldError For="@(() => SubjectivityModel.HasEmployeesOutsideWisconsin)"
                    Visible="_formSubmitted" />
                </div>
            }

            @if (Section6Visible())
            {
                <div id="section_6" class="ui-radio-section">
                    <Tooltip Text="For-profit entities paying State Unemployment Tax (SUTA) in a state other than Wisconsin often have a FUTA liability. Some non-profit entities may owe SUTA but not FUTA. More details on FUTA liability can be found on the IRS website: <a href='https://www.irs.gov/taxtopics/tc759' target='_blank' rel='noopener noreferrer'> Topic no. 759, Form 940, Employers Annual Federal Unemployment (FUTA) Tax Return – filing and deposit requirements | Internal Revenue Service </a>"
                             AllowHtml="true"
                             Placement="auto">
                        <p class="ui-text">Do you have a <a href='https://www.irs.gov/taxtopics/tc759' target='_blank' rel='noopener noreferrer'> Federal Unemployment Tax (FUTA)</a> liability based on payrolls in any state other than Wisconsin?</p>
                    </Tooltip>

                    <RadioGroup TValue="bool?"
                                Value="SubjectivityModel.HasFutaLiabilityInOtherStates"
                                ValueChanged="OnHasFutaLiabilityInOtherStatesChange"
                                ValueExpression="() => SubjectivityModel.HasFutaLiabilityInOtherStates"
                                Options="@HasHasFutaLiabilityInOtherStates" />
                    <FieldError For="@(() => SubjectivityModel.HasFutaLiabilityInOtherStates)"
                                Visible="_formSubmitted" />
                </div>
            }

            @if (Section4Visible())
            {
                <div id="section_4" class="ui-radio-section">
                    <p class="ui-text">@GetWagesQuestion()</p>
                    <RadioGroup TValue="bool?"
                                Value="SubjectivityModel.PaidWagesOver1500Employees"
                                ValueChanged="OnPaidWagesOver1500EmployeesChange"
                                ValueExpression="() => SubjectivityModel.PaidWagesOver1500Employees"
                                Options="@HasPaidWagesOver1500Employees" />
                    <FieldError For="@(() => SubjectivityModel.PaidWagesOver1500Employees)"
                                Visible="_formSubmitted" />
                </div>
            }

            @if (Section5Visible())
            {
                <div id="section_5" class="ui-radio-section">
                    <p class="ui-text">Quarter and year in which you first paid $1500 (q/yyyy):</p>
                    <div class="form-row row">
                        <div class="form-group col-md-12">
                            <OutlinedTextField Label="Quarter and Year (q/yyyy)"
                                               @bind-Value="SubjectivityModel.FirstWageQuarterYearEmployees"
                                               For="() => SubjectivityModel.FirstWageQuarterYearEmployees"
                                               Visible="_formSubmitted" />
                            <FieldError For="@(() => _formSubmitted)" Visible=_formSubmitted />
                        </div>
                    </div>
                </div>
            }


            @if (Section9Visible())
            {
                <div id="section_9" class="ui-radio-section">
                    <p class="ui-text">Have you had at least one full- or part-time employee working for you in 20 different calendar weeks in a calendar year?</p>
                    <RadioGroup TValue="bool?"
                                Value="SubjectivityModel.HasEmployeeIn20Weeks"
                                ValueChanged="OnHasEmployeeIn20WeeksChange"
                                ValueExpression="() => SubjectivityModel.HasEmployeeIn20Weeks"
                                Options="@HasPaidHasEmployeeIn20Weeks" />
                    <FieldError For="@(() => SubjectivityModel.HasEmployeeIn20Weeks)"
                                Visible="_formSubmitted" />
                </div>
            }


            @if (Section13Visible())
            {
                <div id="section_3" class="ui-radio-section">
                    <p class="ui-text">@GetExpectToPayWagesQuestion()</p>
                    <RadioGroup TValue="bool?"
                                Value="SubjectivityModel.ExpectToPayWagesInAQuarter"
                                ValueChanged="OnExpectToPayWagesInAQuarterChange"
                                ValueExpression="() => SubjectivityModel.ExpectToPayWagesInAQuarter"
                                Options="@ExpectToPayWagesInAQuarter" />
                    <FieldError For="@(() => SubjectivityModel.ExpectToPayWagesInAQuarter)"
                                Visible="_formSubmitted" />
                </div>
            }

            @if(Section14Visible())
            {
                <div id="section_14" class="ui-radio-section">
                    <p class="ui-text">When?</p>
                    <OutlinedSelectField @bind-Value="SubjectivityModel.WhenExpectToPayWagesInAQuarter"
                                         Options="@ExpectedWagesCatagories"
                                         For="() => SubjectivityModel.WhenExpectToPayWagesInAQuarter"
                                         Visible="true" />
                </div>
                
            }


@*             @if (SubjectivityModel.HasFutaLiabilityInOtherStates.HasValue && !SubjectivityModel.HasFutaLiabilityInOtherStates.Value)

 *@         @if (Section7Visible())
            {
                <div id="section_7" class="ui-radio-section">
                    <p class="ui-text">@GetWagesQuestion()</p>
                    <RadioGroup TValue="bool?"
                                Value="SubjectivityModel.PaidWagesOrTaxesOver1500"
                                ValueChanged="OnPaidWagesOrTaxesOver1500Change"
                                ValueExpression="() => SubjectivityModel.PaidWagesOrTaxesOver1500"
                                Options="@HasPaidWagesOrTaxesOver1500" />
                    <FieldError For="@(() => SubjectivityModel.PaidWagesOrTaxesOver1500)"
                                Visible="_formSubmitted" />
                </div>
            }

            @if (Section8Visible())
            {
                <div id="section_8" class="ui-radio-section">
                    <p class="ui-text">Quarter and year in which you first paid $1500 (q/yyyy):</p>
                    <div class="form-row row">
                        <div class="form-group col-md-12">
                            <OutlinedTextField Label="Quarter and Year (q/yyyy)"
                                               @bind-Value="SubjectivityModel.QuarterYearFirstPaidTaxes"
                                               For="() => SubjectivityModel.QuarterYearFirstPaidTaxes"
                                               Visible="_formSubmitted" />
                            <FieldError For="@(() => SubjectivityModel.QuarterYearFirstPaidTaxes)"
                                        Visible="_formSubmitted" />
                        </div>
                    </div>
                </div>

            }



        @if (Section11Visible())
        {
            <div id="section_9" class="ui-radio-section">
                <p class="ui-text">Have you had at least 4 full or part-time employees working for you in Wisconsin on the same day in 20 different calendar weeks in a calendar year?</p>
                <RadioGroup TValue="bool?"
                            Value="SubjectivityModel.Employee20WeeksFourOrMore"
                            ValueChanged="OnEmployee20WeeksFourOrMoreChange"
                            ValueExpression="() => SubjectivityModel.Employee20WeeksFourOrMore"
                            Options="@HasPaidHasEmployeeIn20Weeks" />
                <FieldError For="@(() => SubjectivityModel.Employee20WeeksFourOrMore)"
                            Visible="_formSubmitted" />
            </div>
        }


        @if (Section10Visible())

            @*             @if (SubjectivityModel.HasEmployeeIn20Weeks.HasValue && SubjectivityModel.HasEmployeeIn20Weeks.Value)
 *@            {
                <div id="section_10" class="form-row row ui-radio-section">
                    <div class="form-group col-md-6">

                        <label class="form-label" for="Week20EndDate">
                            Date 20th Week Ended
                        </label>
                        <InputDate id="Week20EndDate"
                                   @bind-Value="SubjectivityModel.Week20EndDate"
                                   class="form-control"
                                   DisplayName="Date 20th Week Ended"
                                   @bind-Value:format="MM/dd/yyyy" />
                        <FieldError For="@(() => SubjectivityModel.Week20EndDate)"
                                    Visible="_formSubmitted" />
                    </div>
                </div>
            }

            @if (SubjectivityModel.Wages != null && SubjectivityModel.Wages.Count > 0 && BusinessCategory != BusinessCategory.NonProfit_501c3)
            {
                <p class="ui-text">@GetWagesTableDisclaimer()</p>
                <table>
                    <tr style="text-align:center;">
                        <th></th>
                        <th>Q1</th>
                        <th>Q2</th>
                        <th>Q3</th>
                        <th>Q4</th>
                    </tr>
                    @foreach (var row in SubjectivityModel.Wages)
                    {
                        <tr class"ui-table-row-header">
                            <td class="ui-table-row-header">@row.Year</td>

                            <td class="ui-table-text-box">
                                <NumericTextBox @bind-Value="row.Q1Wages"
                                                InputType="@InputDataTypes.Currency"
                                                ShowCurrencyIcon="false"
                                                CssClass="@(row.Q1Disabled ? "textboxReadOnlyBackgroundColor" : "")"
                                                DecimalPlaces="@DecimalPlaces"
                                                IsReadonly="@row.Q1Disabled"
                                                Min="0" Max="10000000" />
                            </td>

                            <td class="ui-table-text-box">
                                <NumericTextBox @bind-Value="row.Q2Wages"
                                                InputType="@InputDataTypes.Currency"
                                                ShowCurrencyIcon="false"
                                                CssClass="@(row.Q2Disabled ? "textboxReadOnlyBackgroundColor" : "")"
                                                DecimalPlaces="@DecimalPlaces"
                                                IsReadonly="@row.Q2Disabled"
                                                Min="0" Max="10000000" />

                            </td>

                            <td class="ui-table-text-box">
                                <NumericTextBox @bind-Value="row.Q3Wages"
                                                InputType="@InputDataTypes.Currency"
                                                CssClass="@(row.Q3Disabled ? "textboxReadOnlyBackgroundColor" : "")"
                                                ShowCurrencyIcon="false"
                                                DecimalPlaces="@DecimalPlaces"
                                                IsReadonly="@row.Q3Disabled"
                                                Min="0" Max="10000000" />

                            </td>

                            <td class="ui-table-text-box">
                                <NumericTextBox @bind-Value="row.Q4Wages"
                                                InputType="@InputDataTypes.Currency"
                                                CssClass="@(row.Q4Disabled ? "textboxReadOnlyBackgroundColor" : "")"
                                                ShowCurrencyIcon="false"
                                                DecimalPlaces="@DecimalPlaces"
                                                IsReadonly="@row.Q4Disabled"
                                                Min="0" Max="10000000" />

                            </td>
                        </tr>
                    }

                </table>

                @if (_insufficientQuarterlyWageEntered)
                {
                    <div class="field-error" role="alert" aria-label="@($"Validation error for Wage Entry")">
                        <span class="field-error__icon" aria-hidden="true">
                            @GetMasterAlertErrorIcon()
                        </span>

                        <span class="field-error__text">
                            Insufficient quarterly wages reported.
                        </span>
                    </div>
                }                
            }
            <br />
            <br />

        </EditForm>

        <br />
        <Button Text="Validate" OnClick="Validate"></Button>

    </div>
</div>


