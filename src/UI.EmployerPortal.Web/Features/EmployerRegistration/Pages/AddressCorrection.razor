@page "/employer-registration/address-correction"
@using UI.EmployerPortal.Web.Features.EmployerRegistration.Services
@using UI.EmployerPortal.Web.Features.Shared.Components
@rendermode InteractiveServer

<PageTitle>Address Correction</PageTitle>

@if (_items.Count > 0)
{
    <SharedAddressCorrection Corrections="@_items"
                             OnEditAddress="EditAddress"
                             OnContinue="HandleContinue" />
}

@code {
    [Inject] private RegistrationStateService RegistrationState { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private List<UI.EmployerPortal.Razor.SharedComponents.Model.AddressCorrectionItem> _items = new();

    protected override void OnInitialized()
    {
        _items = RegistrationState.AddressCorrections;

        // if there are not any corrections that are more than a zip/capitolization change, we can just apply the changes and nav back
        if (!_items.Exists(ac => !ac.IsOnlyCapitalizationOrZipExtensionChange))
        {
            ApplyAndNavigate();
        }
    }

    /// <summary>Returns the user to the originating step to edit their address.</summary>
    private void EditAddress()
    {
        RegistrationState.CurrentStep = RegistrationState.EditStep;
        RegistrationState.ContinueActionClick = false; 
        Nav.NavigateTo("employer-registration/steps");
    }

    /// <summary>Applies all accepted corrections then navigates to the next step.</summary>
    private void HandleContinue(List<UI.EmployerPortal.Razor.SharedComponents.Model.AddressCorrectionItem> correctedItems)
    {
        // The items have already been modified by SharedAddressCorrection, 
        // we just need to mirror them if necessary and navigate.
        ApplyAndNavigate();
    }

    private void ApplyAndNavigate()
    {
        for (var i = 0; i < _items.Count; i++)
        {
            var item = _items[i];
            
            // Mirror mailing correction to physical[0] when it is a copy of mailing
            if (RegistrationState.PhysicalSameAsMailing &&
                RegistrationState.BusinessInfo is not null &&
                ReferenceEquals(item.Original, RegistrationState.BusinessInfo.MailingAddress) &&
                item.Suggested != null)
            {
                SharedAddressCorrection.ApplyCorrection(RegistrationState.BusinessInfo.PhysicalLocations[0], item.Suggested);
            }
        }

        RegistrationState.CurrentStep = RegistrationState.EditStep;
        RegistrationState.ContinueActionClick = true;
        Nav.NavigateTo("employer-registration/steps");
    }
}
