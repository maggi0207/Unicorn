@page "/manage-account/account-details"
@using UI.EmployerPortal.Web.Features.ManageAccount.Models
@using UI.EmployerPortal.Web.Features.ManageAccount.Services
@using UI.EmployerPortal.Razor.SharedComponents.Inputs
@using UI.EmployerPortal.Razor.SharedComponents.Navigation
@using Microsoft.AspNetCore.Components.Forms
@inject NavigationManager NavigationManager
@inject IAccountDetailsService AccountDetailsService

<PageTitle>Update Account Information</PageTitle>

<div class="account-details-page">
    <h1 class="page-title fw-bold">Update Account Information</h1>
    
    <div class="manage-addresses-link mb-3">
        <a href="manage-account/manage-addresses" class="fw-bold">Manage Addresses</a>
    </div>

    <p class="required-text mb-4">All fields are required unless noted.</p>

    @if (_isLoading)
    {
        <p>Loading account details...</p>
    }
    else
    {
        <EditForm Model="@_model" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />

            <div class="row align-items-start mb-3">
                <div class="col-md-5">
                    <FEINField Label="FEIN" @bind-Value="_model.FEIN" For="@(() => _model.FEIN)" />
                </div>
                <div class="col-md-5 offset-md-1">
                    <OutlinedSelectField Label="Reason for FEIN Change" 
                                         @bind-Value="_model.ReasonForFeinChange" 
                                         For="@(() => _model.ReasonForFeinChange)"
                                         Options="@_reasonOptions" />
                </div>
            </div>

            <div class="row align-items-start mb-3">
                <div class="col-md-5">
                    <OutlinedTextField Label="Legal Name" @bind-Value="_model.LegalName" For="@(() => _model.LegalName)" />
                </div>
                <div class="col-md-5 offset-md-1">
                    <OutlinedSelectField Label="Reason for Legal Name Change" 
                                         @bind-Value="_model.ReasonForLegalNameChange" 
                                         For="@(() => _model.ReasonForLegalNameChange)"
                                         Options="@_reasonOptions" />
                </div>
            </div>

            <div class="row align-items-start mb-3">
                <div class="col-md-5">
                    <OutlinedTextField Label="Trade Name (optional)" @bind-Value="_model.TradeName" For="@(() => _model.TradeName)" />
                </div>
            </div>

            <div class="row align-items-start mb-3">
                <div class="col-md-5">
                    <PhoneNumberField Label="Phone Number" 
                                      @bind-Value="_model.PhoneNumber" 
                                      For="@(() => _model.PhoneNumber)" 
                                      @bind-Extension="_model.Extension" />
                </div>
            </div>

            <div class="row align-items-start mb-5">
                <div class="col-md-5">
                    <OutlinedTextField Label="Email Address" @bind-Value="_model.EmailAddress" For="@(() => _model.EmailAddress)" />
                </div>
            </div>

            <ButtonBar ShowBack="true" 
                       ShowContinue="true" 
                       ShowCancel="false" 
                       ShowSaveAndQuit="false" 
                       BackText="CANCEL" 
                       ContinueText="SAVE" 
                       OnBack="Cancel">
            </ButtonBar>
        </EditForm>
    }
</div>

@code {
    /// <summary>
    /// The view model holding the account details bound to the form.
    /// </summary>
    private AccountDetailsModel _model = new();

    /// <summary>
    /// Indicates whether the page is currently loading data.
    /// </summary>
    private bool _isLoading = true;

    /// <summary>
    /// Options for the FEIN and Legal Name change reason dropdowns.
    /// </summary>
    private List<SelectOption> _reasonOptions = new()
    {
        new SelectOption { Value = "Correction", Text = "Correction" },
        new SelectOption { Value = "ChangeOfOwnership", Text = "Change of Ownership" },
        new SelectOption { Value = "Other", Text = "Other" }
    };

    /// <summary>
    /// Initializes the component by fetching the existing account details from the service.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        _model = await AccountDetailsService.GetAccountDetailsAsync();
        _isLoading = false;
    }

    /// <summary>
    /// Handles the form submission when all validation passes.
    /// Saves the updated account details and navigates back to the manage account page.
    /// </summary>
    private async Task HandleValidSubmit()
    {
        var success = await AccountDetailsService.UpdateAccountDetailsAsync(_model);
        
        if (success)
        {
            NavigationManager.NavigateTo("/manage-account?success=true");
        }
    }

    /// <summary>
    /// Cancels the update operation and navigates back to the manage account page.
    /// </summary>
    private void Cancel()
    {
        NavigationManager.NavigateTo("/manage-account");
    }
}
