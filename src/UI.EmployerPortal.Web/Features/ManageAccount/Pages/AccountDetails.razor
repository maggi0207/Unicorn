@page "/manage-account/account-details"
@using UI.EmployerPortal.Web.Features.ManageAccount.Models
@using UI.EmployerPortal.Razor.SharedComponents.Inputs
@using UI.EmployerPortal.Razor.SharedComponents.NotificationBanners
@using Microsoft.AspNetCore.Components.Forms
@using System.Linq.Expressions
@inject NavigationManager NavigationManager
@using UI.EmployerPortal.Web.Features.Shared.Session.Managers
@using UI.EmployerPortal.Web.Features.Shared.Session.Models
@using UI.EmployerPortal.Web.Features.ManageAccount.Services
@inject IAccountDetailsService AccountDetailsService
@inject ISessionManager SessionManager

<PageTitle>Update Account Information</PageTitle>

<div class="account-details-page">
    <h1 class="page-title" aria-label="update-account-information">Update Account Information</h1>

    <div class="manage-addresses-link">
        <a href="manage-account/manage-addresses" aria-label="Navigate to Manage Addresses">Manage Addresses</a>
    </div>

    <p class="required-text" aria-label="noted-required-fields">All fields are required unless noted.</p>

    @using UI.EmployerPortal.Razor.SharedComponents

    @if (_editContext == null)
    {
        <LoadingSpinner Message="Loading account details..." />
    }
    else
    {
        @* ── Validation Error Summary ── *@
        @if (_formSubmitted && _validationErrors.Any())
        {
            <NotificationBanner NotificationType="NotificationType.Alert"
                                MessageStyle="MessageStyle.MultiLine"
                                Messages="_validationErrors"
                                MessageFieldIds="_validationFieldIds"
                                DismissButton="false">
            </NotificationBanner>
            <br />
        }

        <EditForm EditContext="@_editContext" FormName="AccountDetails" OnSubmit="HandleSubmit" role="form">

            <DataAnnotationsValidator />

            @* ── Row 1: FEIN + Reason for FEIN Change ── *@
            <div class="ad-fields-grid" aria-label="FEIN details">
                <div class="ad-field" aria-label="fein">
                    <FEINField Label="FEIN"
                               Id="FEIN"
                               @bind-Value="_model.FEIN"
                               For="@(() => _model.FEIN)"
                               Visible="@IsVisible(() => _model.FEIN)" />
                </div>
                <div class="ad-field" aria-label="reason-for-fein-change">
                    <OutlinedSelectField Label="Reason for FEIN Change"
                                         Id="ReasonForFeinChange"
                                         @bind-Value="_model.ReasonForFeinChange"
                                         For="@(() => _model.ReasonForFeinChange)"
                                         Options="@_feinReasonOptions" />
                </div>
            </div>

            @* ── Row 2: Legal Name + Reason for Legal Name Change ── *@
            <div class="ad-fields-grid" aria-label="Legal name details">
                <div class="ad-field" aria-label="legal-name">
                    <OutlinedTextField Label="Legal Name"
                                       Id="LegalName"
                                       @bind-Value="_model.LegalName"
                                       For="@(() => _model.LegalName)"
                                       Visible="@IsVisible(() => _model.LegalName)" />
                </div>
                <div class="ad-field" aria-label="reason-for-legal-name-change">
                    <OutlinedSelectField Label="Reason for Legal Name Change"
                                         Id="ReasonForLegalNameChange"
                                         @bind-Value="_model.ReasonForLegalNameChange"
                                         For="@(() => _model.ReasonForLegalNameChange)"
                                         Options="@_legalNameReasonOptions" />
                </div>
            </div>

            @* ── Row 3: Trade Name (single column) ── *@
            <div class="ad-field-single" aria-label="trade-name">
                <OutlinedTextField Label="Trade Name (optional)"
                                   Id="TradeName"
                                   @bind-Value="_model.TradeName"
                                   For="@(() => _model.TradeName)" />
            </div>

            @* ── Row 4: Phone Number (single column) ── *@
            <div class="ad-field-single" aria-label="phone-number">
                <PhoneNumberField Label="Phone Number"
                                  Id="PhoneNumber"
                                  @bind-Value="_model.PhoneNumber"
                                  For="@(() => _model.PhoneNumber)"
                                  @bind-Extension="_model.Extension"
                                  Placeholder="(999) 999-9999"
                                  ExtensionPlaceholder="Ext. 99"
                                  Visible="@IsVisible(() => _model.PhoneNumber)" />
            </div>

            @* ── Row 5: Email Address (single column) ── *@
            <div class="ad-field-single" aria-label="email-address">
                <OutlinedTextField Label="Email Address"
                                   Id="EmailAddress"
                                   Type="email"
                                   @bind-Value="_model.EmailAddress"
                                   For="@(() => _model.EmailAddress)"
                                   Visible="@IsVisible(() => _model.EmailAddress)" />
            </div>

            @* ── Buttons ── *@
            <div class="button-bar-custom" role="group" aria-label="Form actions">
                <button type="button"
                        class="btn-cancel"
                        aria-label="Cancel and return to manage account"
                        @onclick="Cancel">CANCEL</button>
                <button type="submit"
                        class="btn-save"
                        aria-label="Save account information changes">SAVE</button>
            </div>

        </EditForm>
    }
    </div>

@code {
    /// <summary>
    /// The view model holding the account details bound to the form.
    /// </summary>
    private AccountDetailsModel _model = new();

    /// <summary>
    /// The EditContext used for form validation and field change tracking.
    /// </summary>
    private EditContext _editContext = default!;


    /// <summary>
    /// Tracks whether the form has been submitted, controlling error visibility.
    /// </summary>
    private bool _formSubmitted = false;

    /// <summary>
    /// Tracks which fields the user has interacted with so errors show on field change.
    /// </summary>
    private readonly HashSet<FieldIdentifier> _touchedFields = new();

    /// <summary>
    /// The currently selected employer SK from the session.
    /// </summary>
    private int _employerSK = 0;

    /// <summary>
    /// The list of validation error messages displayed in the NotificationBanner.
    /// </summary>
    private List<string> _validationErrors = new();

    /// <summary>
    /// The list of field IDs corresponding to validation errors, enabling banner-to-field navigation.
    /// </summary>
    private List<string> _validationFieldIds = new();

    /// <summary>
    /// Options for the FEIN change reason dropdown.
    /// </summary>
    private List<SelectOption> _feinReasonOptions = new()
    {
        new SelectOption { Value = "1", Text = "EntryError" },
        new SelectOption { Value = "5", Text = "Other (additional explanation required)" }
    };

    /// <summary>
    /// Options for the Legal Name change reason dropdown.
    /// </summary>
    private List<SelectOption> _legalNameReasonOptions = new()
    {
        new SelectOption { Value = "1", Text = "Department of Financial Institutions Name Change" },
        new SelectOption { Value = "2", Text = "Department Error" },
        new SelectOption { Value = "5", Text = "Other (additional explanation required)" }
    };

    /// <summary>
    /// Initializes the EditContext with data from the backend and sets up field change tracking.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        var sessionState = await SessionManager.GetAsync<UI.EmployerPortal.Web.Features.Shared.Accounts.Models.SelectedEmployerAccount>();
        _employerSK = sessionState?.EmployerAccount?.Id ?? 0;

        if (_employerSK > 0)
        {
            _model = await AccountDetailsService.GetAccountDetailsAsync(_employerSK);
        }
        else
        {
            _model = new AccountDetailsModel();
        }

        _editContext = new EditContext(_model);

        // Track field interactions for progressive error display
        _editContext.OnFieldChanged += (_, e) =>
        {
            _touchedFields.Add(e.FieldIdentifier);

            if (_formSubmitted)
            {
                InvokeAsync(() =>
                {
                    RefreshValidationSummary();
                    StateHasChanged();
                });
            }
            else
            {
                StateHasChanged();
            }
        };
    }

    /// <summary>
    /// Handles form submission. Validates the form first; if valid, saves to backend and navigates back.
    /// </summary>
    private async Task HandleSubmit()
    {
        _formSubmitted = true;
        _validationErrors.Clear();
        _validationFieldIds.Clear();

        var isValid = _editContext.Validate();

        RefreshValidationSummary();

        if (!isValid)
        {
            StateHasChanged();
            return;
        }

        var result = await AccountDetailsService.UpdateAccountDetailsAsync(_model, _employerSK);

        if (result.success)
        {
            NavigationManager.NavigateTo("/manage-account?success=true");
        }
        else
        {
            _validationErrors.Add(result.error);
            StateHasChanged();
        }
    }

    /// <summary>
    /// Refreshes the validation summary by collecting all field errors in UI layout order.
    /// </summary>
    private void RefreshValidationSummary()
    {
        if (!_formSubmitted) return;

        _validationErrors.Clear();
        _validationFieldIds.Clear();

        // Collect errors in UI layout order
        var fieldOrder = new[]
        {
            nameof(_model.FEIN),
            nameof(_model.LegalName),
            nameof(_model.PhoneNumber),
            nameof(_model.EmailAddress)
        };

        foreach (var fieldName in fieldOrder)
        {
            var fi = new FieldIdentifier(_model, fieldName);
            foreach (var error in _editContext.GetValidationMessages(fi))
            {
                _validationErrors.Add(error);
                _validationFieldIds.Add(fieldName);
            }
        }
    }

    /// <summary>
    /// Returns true when a field's errors should be visible (after form submission or user interaction).
    /// </summary>
    private bool IsVisible(Expression<Func<string?>> For)
    {
        return _formSubmitted || _touchedFields.Contains(FieldIdentifier.Create(For));
    }

    /// <summary>
    /// Cancels the update operation and navigates back to the manage account page.
    /// </summary>
    private void Cancel()
    {
        NavigationManager.NavigateTo("/manage-account");
    }
}
