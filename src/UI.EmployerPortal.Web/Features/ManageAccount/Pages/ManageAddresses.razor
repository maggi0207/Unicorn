@page "/manage-account/manage-addresses"
@using UI.EmployerPortal.Razor.SharedComponents
@using UI.EmployerPortal.Razor.SharedComponents.NotificationBanners
@using UI.EmployerPortal.Razor.SharedComponents.Inputs
@using Microsoft.AspNetCore.Components.Forms
@using UI.EmployerPortal.Web.Features.ManageAccount.Models
@using UI.EmployerPortal.Web.Features.ManageAccount.Services
@using UI.EmployerPortal.Web.Features.Shared.Session.Managers

<PageTitle>Manage Addresses</PageTitle>

<div class="page-content">

    @if (_isLoading)
    {
        <LoadingSpinner Message="Loading addresses..." />
    }
    else if (_loadError)
    {
        <NotificationBanner NotificationType="NotificationType.Alert"
                            MessageStyle="MessageStyle.MultiLine"
                            Messages='new List<string> { "Unable to load addresses. Please try again." }'
                            DismissButton="false" />
    }
    else
    {
    @if (_showForm && _editContext != null)
    {
        <h1 class="page-title fw-bold mb-2">@(_isEditMode ? "Edit Address" : "Add Address")</h1>
        <p class="fw-normal fs-md mb-4">All fields are required unless noted.</p>

        @if (_formErrors.Any())
        {
            <NotificationBanner NotificationType="NotificationType.Alert"
                                MessageStyle="MessageStyle.MultiLine"
                                Messages="_formErrors"
                                DismissButton="false" />
            <br />
        }

        <EditForm EditContext="@_editContext" OnSubmit="HandleFormSubmitAsync">
            <DataAnnotationsValidator />

            @* Address Type ──────────────────────────────── *@
            <div class="row mb-3" style="max-width: 800px;">
                <div class="col-md-6 col-12">
                    <OutlinedSelectField Label="Address Type"
                                         Id="AddressType"
                                         @bind-Value="_addressTypeValue"
                                         For="@(() => _addressTypeValue)"
                                         Options="@_addressTypeOptions" />
                </div>
            </div>

            @* Country / Format ─────────────────────────────── *@
            <div class="row mb-3" style="max-width: 800px;">
                <div class="col-md-6 col-12">
                    <OutlinedSelectField Label="Country"
                                         Id="AddressCountry"
                                         @bind-Value="_countryValue"
                                         For="@(() => _countryValue)"
                                         Options="@_countryOptions" />
                </div>
            </div>

            @* Line 1 and 2 ─────────────────────────────────────────── *@
            <div class="row mb-3" style="max-width: 800px;">
                <div class="col-md-6 col-12">
                    <OutlinedTextField Label="Address Line 1"
                                       Id="LineOneAddress"
                                       @bind-Value="_formModel.LineOneAddress"
                                       For="@(() => _formModel.LineOneAddress)"
                                       Visible="@_formSubmitted"
                                       MaxLength="100" />
                </div>
                <div class="col-md-6 col-12 mt-3 mt-md-0">
                    <OutlinedTextField Label="Address Line 2 (optional)"
                                       Id="LineTwoAddress"
                                       @bind-Value="_formModel.LineTwoAddress"
                                       For="@(() => _formModel.LineTwoAddress)"
                                       MaxLength="100" />
                </div>
            </div>

            @* US / Canada: City + State/Province ─────────────── *@
            @if (_formModel.CountryAddressFormatCodeSK != 3)
            {
                <div class="row mb-3" style="max-width: 800px;">
                    <div class="col-md-6 col-12">
                        <OutlinedTextField Label="City"
                                           Id="CityName"
                                           @bind-Value="_formModel.CityName"
                                           For="@(() => _formModel.CityName)"
                                           Visible="@_formSubmitted"
                                           MaxLength="50" />
                    </div>

                    @if (_formModel.CountryAddressFormatCodeSK == 1)
                    {
                        @* US: State dropdown ──────────────────── *@
                        <div class="col-md-6 col-12 mt-3 mt-md-0">
                            <OutlinedSelectField Label="State"
                                                 Id="StateCodeSK"
                                                 @bind-Value="_stateValue"
                                                 For="@(() => _stateValue)"
                                                 Options="@_stateOptions" />
                        </div>
                    }
                    else
                    {
                        @* Canada: Province dropdown ─────────────────── *@
                        <div class="col-md-6 col-12 mt-3 mt-md-0">
                            <OutlinedSelectField Label="Province"
                                                 Id="ProvinceCodeSK"
                                                 @bind-Value="_provinceValue"
                                                 For="@(() => _provinceValue)"
                                                 Options="@_provinceOptions" />
                        </div>
                    }
                </div>

                @if (_formModel.CountryAddressFormatCodeSK == 1)
                {
                    @* US: ZIP ───────────────────────────────────────── *@
                    <div class="row mb-3" style="max-width: 800px;">
                        <div class="col-md-6 col-12">
                            <div class="d-flex align-items-center">
                                <div style="flex: 1;">
                                    <OutlinedTextField Label="Zip Code"
                                                       Id="ZipCode"
                                                       @bind-Value="_formModel.ZipCode"
                                                       For="@(() => _formModel.ZipCode)"
                                                       Visible="@_formSubmitted"
                                                       MaxLength="5" />
                                </div>
                                <span class="mx-2 fw-bold text-muted">-</span>
                                <div style="flex: 1;">
                                    <OutlinedTextField Label="+4 (Optional)"
                                                       Id="ZipExtension"
                                                       @bind-Value="_formModel.ZipExtension"
                                                       For="@(() => _formModel.ZipExtension)"
                                                       MaxLength="4" />
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    @* Canada: Postal Code ───────────────────────────── *@
                    <div class="row mb-3" style="max-width: 800px;">
                        <div class="col-md-6 col-12">
                            <OutlinedTextField Label="Postal Code"
                                               Id="CanadianPostalCode"
                                               @bind-Value="_formModel.CanadianPostalCode"
                                               For="@(() => _formModel.CanadianPostalCode)"
                                               Visible="@_formSubmitted"
                                               Placeholder="A1A 1A1"
                                               MaxLength="7" />
                        </div>
                    </div>
                }
            }
            else
            {
                @* International: Lines 3 + 4 ─────────────────── *@
                <div class="row mb-3" style="max-width: 800px;">
                    <div class="col-md-6 col-12">
                        <OutlinedTextField Label="Address Line 3 (optional)"
                                           Id="LineThreeAddress"
                                           @bind-Value="_formModel.LineThreeAddress"
                                           For="@(() => _formModel.LineThreeAddress)"
                                           MaxLength="100" />
                    </div>
                    <div class="col-md-6 col-12 mt-3 mt-md-0">
                        <OutlinedTextField Label="Address Line 4 (optional)"
                                           Id="LineFourAddress"
                                           @bind-Value="_formModel.LineFourAddress"
                                           For="@(() => _formModel.LineFourAddress)"
                                           MaxLength="100" />
                    </div>
                </div>
            }

            @* Form Buttons ────────────────────────────────────── *@
            <div class="d-flex justify-content-between mt-5" style="max-width: 800px;" role="group" aria-label="Address form actions">
                <button type="button"
                        class="btn fw-bold px-4 rounded-1"
                        style="border: 2px solid #003663; color: #003663; background: #fff; min-width: 120px;"
                        @onclick="HandleFormCancel"
                        aria-label="Cancel address edit">
                    CANCEL
                </button>
                <button type="submit"
                        class="btn fw-bold px-4 rounded-1"
                        style="background-color: #003663; color: #fff; border: 2px solid #003663; min-width: 120px;"
                        disabled="@_isSaving"
                        aria-label="Save address">
                    @if (_isSaving)
                    {
                        <span>SAVING...</span>
                    }
                    else
                    {
                        <span>SAVE</span>
                    }
                </button>
            </div>
        </EditForm>
    }
    else
    {
        <h1 class="page-title fw-bold">Manage Addresses</h1>

        @if (!string.IsNullOrWhiteSpace(_successMessage))
        {
            <div class="flash-banner-wrapper">
                <NotificationBanner @key="_bannerKey"
                                    NotificationType="NotificationType.Confirmation"
                                    MessageStyle="MessageStyle.SingleLine"
                                    Message="@_successMessage"
                                    DismissButton="true" />
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <div class="flash-banner-wrapper">
                <NotificationBanner NotificationType="NotificationType.Alert"
                                    MessageStyle="MessageStyle.SingleLine"
                                    Message="@_errorMessage"
                                    DismissButton="false" />
            </div>
        }

        <div class="table-container">
            <table class="table" style="table-layout: fixed; width: 100%;" aria-label="Employer addresses">
                <caption class="visually-hidden">List of employer addresses with address type and actions</caption>
                <thead>
                    <tr class="header-row">
                        <th scope="col" class="header-cell"
                            style="width: 30%;"
                            @onclick="@(() => Sort("addressType"))"
                            @onkeydown="@(e => HandleHeaderKeyDown(e, "addressType"))"
                            tabindex="0"
                            aria-sort="@GetAriaSort("addressType")">
                            <div class="header-content header-content-left">
                                <span class="header-label fw-bold fs-sm">Address Type</span>
                                @GetSortIcon("addressType")
                            </div>
                        </th>
                        <th scope="col" class="header-cell"
                            style="width: 58%;"
                            @onclick="@(() => Sort("address"))"
                            @onkeydown="@(e => HandleHeaderKeyDown(e, "address"))"
                            tabindex="0"
                            aria-sort="@GetAriaSort("address")">
                            <div class="header-content header-content-left">
                                <span class="header-label fw-bold fs-sm">Address</span>
                                @GetSortIcon("address")
                            </div>
                        </th>
                        <th scope="col" class="header-cell actions-cell" style="width: 12%;">
                            <div class="header-content header-content-left">
                                <span class="header-label fw-bold fs-sm">Action</span>
                            </div>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in SortedAddresses)
                    {
                        <tr class="data-row" @key="row.AddressSK">
                            <td class="fw-normal fs-md">@row.AddressType</td>
                            <td class="fw-normal fs-md">@row.FormattedAddress</td>
                            <td>
                                <div class="action-buttons">
                                    <button class="btn btn-sm p-1 action-btn"
                                            title="Edit address"
                                            aria-label="Edit @row.AddressType"
                                            @onclick="() => HandleEditClick(row)">
                                        <img src="@Assets["icons/edit-pen.svg"]" alt="Edit" class="action-icon" />
                                    </button>
                                    @if (row.CanDelete)
                                    {
                                        <button class="btn btn-sm p-1 action-btn"
                                                title="Delete address"
                                                aria-label="Delete @row.AddressType"
                                                @onclick="() => HandleDeleteClick(row)">
                                            <img src="@Assets["icons/trash.svg"]" alt="Delete" class="action-icon" />
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="top-actions" style="padding-top: 8px;">
            <button type="button"
                    class="btn btn-link fw-bold p-0 text-decoration-none d-flex align-items-center gap-1"
                    style="color: #0071bc; font-size: 16px;"
                    aria-label="Add a new address"
                    @onclick="HandleAddClick">
                + Add Address
            </button>
        </div>

        <div style="margin-top: 32px;">
            <button type="button"
                    class="btn btn-outline-secondary fw-bold px-4"
                    aria-label="Cancel and return to account details"
                    @onclick="HandleCancel">
                CANCEL
            </button>
        </div>
    }
    }
</div>


@* ── Delete Confirmation Modal ── *@
@if (_showDeleteModal)
{
    <div class="modal-backdrop fade show" style="z-index: 1040;"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-labelledby="delete-address-title" aria-modal="true" @onclick="CloseDeleteModal" style="z-index: 1050;">
        <div class="modal-dialog modal-dialog-centered" role="document" @onclick:stopPropagation="true">
            <div class="modal-content">
                <div class="modal-header bg-light">
                    <h5 class="modal-title fw-bold d-flex align-items-center gap-2" id="delete-address-title">
                        <img src="@Assets["icons/delete_warning.svg"]" alt="" width="30" height="30" aria-hidden="true" />
                        Delete Address
                    </h5>
                    <button type="button" class="btn-close" aria-label="Close" disabled="@_isDeleting" @onclick="CloseDeleteModal"></button>
                </div>
                <div class="modal-body">
                    @if (_isDeleting)
                    {
                        <LoadingSpinner Message="Deleting address..." />
                    }
                    else if (!string.IsNullOrWhiteSpace(_deleteError))
                    {
                        <p class="text-danger mb-0">@_deleteError</p>
                    }
                    else
                    {
                        <p class="mb-0">
                            Are you sure you want to delete the <strong>@_addressToDelete?.AddressType</strong> address?
                            This action cannot be undone.
                        </p>
                    }
                </div>
                <div class="modal-footer border-top px-3 py-2">
                    @if (!_isDeleting)
                    {
                        <button type="button" class="btn btn-outline-dark fw-bold px-4" @onclick="CloseDeleteModal">CANCEL</button>
                        <button type="button" class="btn btn-danger fw-bold px-4" @onclick="ConfirmDeleteAsync">DELETE</button>
                    }
                </div>
            </div>
        </div>
    </div>
}
